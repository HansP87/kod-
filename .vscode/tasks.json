{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Debug",
      "type": "shell",
      "command": "make",
      "args": [
        "-C",
        "Debug",
        "-j4"
      ],
      "options": {
        "env": {
          "PATH": "${workspaceFolder}/.vscode/toolchain-bin:/Applications/ArmGNUToolchain/15.2.rel1/arm-none-eabi/bin:${env:PATH}"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "Clean Debug",
      "type": "shell",
      "command": "make",
      "args": [
        "-C",
        "Debug",
        "clean"
      ],
      "options": {
        "env": {
          "PATH": "${workspaceFolder}/.vscode/toolchain-bin:/Applications/ArmGNUToolchain/15.2.rel1/arm-none-eabi/bin:${env:PATH}"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Run Smoke Tests",
      "type": "shell",
      "command": "./tests/scripts/run_smoke.sh",
      "options": {
        "env": {
          "PATH": "${workspaceFolder}/.vscode/toolchain-bin:/Applications/ArmGNUToolchain/15.2.rel1/arm-none-eabi/bin:${env:PATH}"
        }
      },
      "problemMatcher": [],
      "group": "test"
    },
    {
      "label": "Dry Run Smoke Tests",
      "type": "shell",
      "command": "./tests/scripts/run_smoke.sh",
      "args": [
        "--dryrun"
      ],
      "options": {
        "env": {
          "PATH": "${workspaceFolder}/.vscode/toolchain-bin:/Applications/ArmGNUToolchain/15.2.rel1/arm-none-eabi/bin:${env:PATH}"
        }
      },
      "problemMatcher": [],
      "group": "test"
    },
    {
      "label": "Run Regression Tests",
      "type": "shell",
      "command": "./tests/scripts/run_all_tests.sh",
      "args": [
        "--level",
        "regression"
      ],
      "options": {
        "env": {
          "PATH": "${workspaceFolder}/.vscode/toolchain-bin:/Applications/ArmGNUToolchain/15.2.rel1/arm-none-eabi/bin:${env:PATH}"
        }
      },
      "problemMatcher": [],
      "group": "test"
    },
    {
      "label": "Run All Tests",
      "type": "shell",
      "command": "./tests/scripts/run_all_tests.sh",
      "args": [
        "--level",
        "all"
      ],
      "options": {
        "env": {
          "PATH": "${workspaceFolder}/.vscode/toolchain-bin:/Applications/ArmGNUToolchain/15.2.rel1/arm-none-eabi/bin:${env:PATH}"
        }
      },
      "problemMatcher": [],
      "group": "test"
    },
    {
      "label": "Dry Run All Tests",
      "type": "shell",
      "command": "./tests/scripts/run_all_tests.sh",
      "args": [
        "--level",
        "all",
        "--dryrun"
      ],
      "options": {
        "env": {
          "PATH": "${workspaceFolder}/.vscode/toolchain-bin:/Applications/ArmGNUToolchain/15.2.rel1/arm-none-eabi/bin:${env:PATH}"
        }
      },
      "problemMatcher": [],
      "group": "test"
    }
  ]
}